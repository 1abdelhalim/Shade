{
  "name": "chrome-extension",
  "version": "1.0.0",
  "description": "Shade Web ports the core Shade behavior to Chrome MV3: detect potentially sensitive content and blur/pixelate regions directly in-browser while staying offline.",
  "main": "index.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "build:offscreen": "node scripts/build-offscreen.mjs",
    "build:content": "node scripts/build-content.mjs",
    "build:sandbox": "node scripts/build-sandbox.mjs",
    "build:models": "node scripts/sync-models.mjs",
    "build": "npm run build:models && npm run build:offscreen && npm run build:sandbox && npm run build:content",
    "test": "node --test \"tests/*.test.mjs\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@tensorflow/tfjs": "^4.9.0",
    "@tensorflow/tfjs-backend-cpu": "^4.9.0",
    "@tensorflow/tfjs-core": "^4.9.0",
    "@tensorflow/tfjs-tflite": "^0.0.1-alpha.10",
    "jsdom": "^29.0.1"
  },
  "devDependencies": {
    "esbuild": "^0.25.4"
  }
}
